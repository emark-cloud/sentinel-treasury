{
  "name": "sentinel-treasury",
  "version": "0.0.0",
  "private": true,
  "description": "Autonomous, self-auditing on-chain treasury manager (Casper Testnet) — Casper Agentic Buildathon 2026",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" --filter \"./apps/**\" run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "runner:build": "pnpm --filter @sentinel/shared build && pnpm --filter orchestrator build",
    "runner": "pnpm runner:build && pnpm --filter orchestrator start",
    "dashboard": "pnpm --filter @sentinel/dashboard dev",
    "dev": "pnpm runner:build && (trap 'kill 0' INT TERM; pnpm --filter orchestrator start & pnpm --filter @sentinel/dashboard dev)"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.10",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
