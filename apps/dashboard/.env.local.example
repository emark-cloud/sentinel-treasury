# Sentinel dashboard (apps/dashboard) — copy to `.env.local` for local runs; on Vercel set these as
# Project Environment Variables instead. All server-side vars stay off the browser (used only in the
# /api/* route handlers); only NEXT_PUBLIC_* reach the client.

# --- agent activity feed: point the dashboard at the running runner (Pillar 2/3) ---
# Local: the runner from `pnpm runner`. Production: the Railway service's public URL.
RUNNER_API_URL=http://127.0.0.1:3002

# --- live vault reads (server-side; omit → in-memory demo vault tagged `demo`) ---
CSPR_CLOUD_ACCESS_TOKEN=
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud
VAULT_ENTITY_HASH=5031341875f4f89629abe7aa748bfa20b0c6ee9c15e9d9910b3047dea9eff7a0
VAULT_CONTRACT_HASH=5031341875f4f89629abe7aa748bfa20b0c6ee9c15e9d9910b3047dea9eff7a0
WISE_LENDING_STAKING_HASH=baa50d1500aa5361c497c06b40f2822ebb0b5fce5b1c3a037ea628cb68d920f3
STABLE_TOKEN_HASH=287873e640fc0dbf3b7bc828a30e1d8ea857649a401b5b5f1ba29ab8bb741100

# --- display-only price/rate (authoritative valuation is the on-chain Styks read) ---
DASHBOARD_TWAP_MICROS=30700
DASHBOARD_SCSPR_STAKED=1052
DASHBOARD_SCSPR_SUPPLY=1000

# --- deposit/redeem submit path (browser → node, no token) ---
NODE_RPC_URL=https://node.testnet.casper.network/rpc
NEXT_PUBLIC_NODE_RPC_URL=https://node.testnet.casper.network/rpc
