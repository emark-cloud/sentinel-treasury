{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @sentinel/shared build && pnpm --filter orchestrator build"
  },
  "deploy": {
    "startCommand": "pnpm --filter orchestrator start",
    "healthcheckPath": "/status",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
