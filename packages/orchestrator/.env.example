# Sentinel runner (packages/orchestrator) — copy to `.env` for local runs; on Railway set these as
# service variables instead (no file). The runner reads its env from the package cwd via dotenv.

# --- secrets (REQUIRED) ---
CSPR_CLOUD_ACCESS_TOKEN=                 # CSPR.cloud API token (also authorizes the x402 facilitator)
GEMINI_API_KEY=                          # Google AI Studio key; omit → deterministic rule-engine fallback

# --- keys ---
AGENT_PUBLIC_KEY=                        # bounded agent key (weight 1) — signs execute_rebalance
OWNER_PUBLIC_KEY=                        # owner key (weight 3) — signs pause(true)
AGENT_SECRET_KEY_PATH=./secrets/agent.pem    # host-local PEM — REQUIRED to run the runner
OWNER_SECRET_KEY_PATH=./secrets/owner.pem    # host-local PEM — enables the circuit-breaker pause tx

# --- deployed contracts (casper-test, D-015; package hashes) ---
VAULT_CONTRACT_HASH=5031341875f4f89629abe7aa748bfa20b0c6ee9c15e9d9910b3047dea9eff7a0
AUDITLOG_CONTRACT_HASH=f8898e6a22590a8e32028d97771384fa54d0fc110cf297ed3f3afb2fecce63f3
CSPR_TRADE_ROUTER_HASH=04a11a367e708c52557930c4e9c1301f4465100d1b1b6d0a62b48d3e32402867
WISE_LENDING_STAKING_HASH=baa50d1500aa5361c497c06b40f2822ebb0b5fce5b1c3a037ea628cb68d920f3
WCSPR_HASH=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
STABLE_TOKEN_HASH=287873e640fc0dbf3b7bc828a30e1d8ea857649a401b5b5f1ba29ab8bb741100
STYKS_PRICE_FEED_HASH=2879d6e927289197aab0101cc033f532fe22e4ab4686e44b5743cb1333031acc

# --- services ---
NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
CSPR_TRADE_MCP_ENDPOINT=                 # self-hosted CSPR.trade MCP; omit → degraded static market
PREMIUM_ENDPOINT_URL=

# --- runner knobs (all optional; sane defaults shown) ---
# PORT is injected by Railway; RUNNER_PORT is the local fallback.
RUNNER_PORT=3002
RUNNER_INTERVAL_MS=1800000               # batch cadence (30 min). Lower for demos, e.g. 120000.
RUNNER_DATA_DIR=./.sentinel-runner       # cycle journal + artifacts + registry + history
RUNNER_ACCOUNTS=                         # optional depositor seed (comma-separated hashes/public keys)
# Policy envelope (deployed D-015 defaults; the contract enforces the per-account clamp regardless):
# RUNNER_PER_ACTION_CAP_USD=50  RUNNER_DAILY_CAP_USD=200  RUNNER_MAX_SLIPPAGE_BPS=100
# RUNNER_MIN_SCSPR_BPS=1500  RUNNER_MAX_SCSPR_BPS=7000
