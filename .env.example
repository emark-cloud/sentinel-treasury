# Sentinel Treasury — environment template.
# Copy to .env and fill in. NEVER commit .env. Private keys live only on the execution host.
# Mirrors the config registry in CLAUDE.md (and resources.md §9). Values are obtained during Phase 0.

# --- Our deployed contracts (filled after Phase-2 deploy) ---
VAULT_CONTRACT_HASH=
AUDITLOG_CONTRACT_HASH=

# --- Keys (public keys here; PRIVATE keys never committed, host-local only) ---
OWNER_PUBLIC_KEY=            # weight 3, key-management
AGENT_PUBLIC_KEY=            # weight 1, signs execute_rebalance
OWNER_SECRET_KEY_PATH=       # e.g. ./keys/owner/secret_key.pem  (gitignored)
AGENT_SECRET_KEY_PATH=       # e.g. ./keys/agent/secret_key.pem  (gitignored)

# --- External Testnet contract hashes/ABIs (ABI spike — top blocker) ---
CSPR_TRADE_ROUTER_HASH=      # + swap/approve entry-point ABI
WISE_LENDING_STAKING_HASH=   # + stake/unstake + sCSPR exchange-rate read
CSPRUSD_CEP18_HASH=
STYKS_PRICE_FEED_HASH=       # get_twap_price("CSPRUSD")

# --- Services / endpoints ---
NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_ACCESS_TOKEN=
GEMINI_API_KEY=              # Google AI Studio (aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash  # fast tier for Risk/Treasury turns; verify latest in AI Studio
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
CSPR_TRADE_MCP_ENDPOINT=
PREMIUM_ENDPOINT_URL=        # we run both ends; + price

# --- Network ---
CASPER_NETWORK=casper-test
X402_NETWORK=casper:casper-test
